# ==============================================================================
# Smart HRMS — Git Ignore Rules
# ==============================================================================

# ------------------------------------------------------------------------------
# Python
# ------------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
.Python
*.pyo
*.pyc

# ------------------------------------------------------------------------------
# Virtual Environments
# ------------------------------------------------------------------------------
venv/
env/
ENV/
.venv/
.env/
virtualenv/
.virtualenv/

# ------------------------------------------------------------------------------
# Environment Variables (CRITICAL — never commit)
# ------------------------------------------------------------------------------
.env
.env.local
.env.production
.env.staging
instance/config.py

# ------------------------------------------------------------------------------
# Flask & Instance
# ------------------------------------------------------------------------------
instance/
!instance/.gitkeep
*.db
*.sqlite
*.sqlite3

# ------------------------------------------------------------------------------
# Logs (keep structure, ignore content)
# ------------------------------------------------------------------------------
logs/*.log
logs/*.log.*
!logs/.gitkeep

# ------------------------------------------------------------------------------
# Uploads
# ------------------------------------------------------------------------------
instance/uploads/
instance/sessions/

# ------------------------------------------------------------------------------
# Testing
# ------------------------------------------------------------------------------
.pytest_cache/
.coverage
htmlcov/
coverage.xml
*.cover
.tox/
nosetests.xml
test-results/

# ------------------------------------------------------------------------------
# IDEs and Editors
# ------------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace

# ------------------------------------------------------------------------------
# Docker
# ------------------------------------------------------------------------------
.docker/

# ------------------------------------------------------------------------------
# Node (if frontend tooling is added later)
# ------------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ------------------------------------------------------------------------------
# Distribution / Packaging
# ------------------------------------------------------------------------------
.Python
*.manifest
*.spec
pip-log.txt
pip-delete-this-directory.txt

# ------------------------------------------------------------------------------
# mypy / type checking
# ------------------------------------------------------------------------------
.mypy_cache/
.dmypy.json
dmypy.json

# ------------------------------------------------------------------------------
# Celery (if added later)
# ------------------------------------------------------------------------------
celerybeat-schedule
celerybeat.pid

# ------------------------------------------------------------------------------
# Sphinx documentation (if added)
# ------------------------------------------------------------------------------
docs/_build/

# Kiro/CI log output files
*.txt
!requirements/*.txt
!requirements.txt
!runtime.txt
!check_result.txt
