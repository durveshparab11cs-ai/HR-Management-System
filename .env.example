# ==============================================================================
# Smart HRMS — Environment Configuration Template
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.
# ==============================================================================

# ------------------------------------------------------------------------------
# Flask Core
# ------------------------------------------------------------------------------
FLASK_ENV=development
FLASK_APP=run.py
FLASK_DEBUG=1
SECRET_KEY=change-this-to-a-long-random-secret-key-in-production

# ------------------------------------------------------------------------------
# Database
# ------------------------------------------------------------------------------
# Development (SQLite)
DATABASE_URL=sqlite:///smart_hrms_dev.db

# Production (PostgreSQL) — uncomment and configure for production
# DATABASE_URL=postgresql://hrms_user:strong_password@localhost:5432/smart_hrms_db

# Database pool settings (production)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600

# ------------------------------------------------------------------------------
# Security
# ------------------------------------------------------------------------------
WTF_CSRF_ENABLED=True
WTF_CSRF_TIME_LIMIT=3600
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax
REMEMBER_COOKIE_DURATION=2592000
REMEMBER_COOKIE_SECURE=False
REMEMBER_COOKIE_HTTPONLY=True
BCRYPT_LOG_ROUNDS=12

# ------------------------------------------------------------------------------
# Mail (SMTP)
# ------------------------------------------------------------------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USE_SSL=False
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password
MAIL_DEFAULT_SENDER=Smart HRMS <noreply@smarthrms.com>
MAIL_MAX_EMAILS=50

# ------------------------------------------------------------------------------
# Rate Limiting
# ------------------------------------------------------------------------------
RATELIMIT_DEFAULT=200 per day;50 per hour
RATELIMIT_STORAGE_URL=memory://
RATELIMIT_STRATEGY=fixed-window

# ------------------------------------------------------------------------------
# Cache
# ------------------------------------------------------------------------------
CACHE_TYPE=SimpleCache
CACHE_DEFAULT_TIMEOUT=300
# Production Redis cache:
# CACHE_TYPE=RedisCache
# CACHE_REDIS_URL=redis://localhost:6379/0

# ------------------------------------------------------------------------------
# Session
# ------------------------------------------------------------------------------
SESSION_TYPE=filesystem
SESSION_FILE_DIR=./instance/sessions
SESSION_PERMANENT=False
PERMANENT_SESSION_LIFETIME=86400

# ------------------------------------------------------------------------------
# File Uploads
# ------------------------------------------------------------------------------
UPLOAD_FOLDER=./instance/uploads
MAX_CONTENT_LENGTH=16777216
ALLOWED_IMAGE_EXTENSIONS=png,jpg,jpeg,gif,webp
ALLOWED_DOCUMENT_EXTENSIONS=pdf,doc,docx,xls,xlsx,csv

# ------------------------------------------------------------------------------
# Logging
# ------------------------------------------------------------------------------
LOG_LEVEL=DEBUG
LOG_DIR=./logs
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=10

# ------------------------------------------------------------------------------
# Application Settings
# ------------------------------------------------------------------------------
APP_NAME=Smart HRMS
APP_VERSION=1.0.0
APP_TIMEZONE=UTC
ITEMS_PER_PAGE=25
ADMIN_EMAIL=admin@smarthrms.com

# ------------------------------------------------------------------------------
# Scheduler (APScheduler)
# ------------------------------------------------------------------------------
SCHEDULER_API_ENABLED=False
SCHEDULER_TIMEZONE=UTC

# ------------------------------------------------------------------------------
# Encryption (for sensitive stored data)
# ------------------------------------------------------------------------------
ENCRYPTION_KEY=change-this-to-32-bytes-base64-encoded-key
